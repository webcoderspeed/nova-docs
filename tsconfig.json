{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@nova-ui": ["./nova-ui/src"],
      "@nova-ui/*": ["./nova-ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "nova-ui/src"
  ],
  "exclude": ["node_modules", "nova-ui/*.ts", "nova-ui/*.js", "nova-ui/*.mts", "nova-ui/src/test-setup.ts", "nova-ui/src/**/*.test.tsx", "nova-ui/src/**/*.test.ts", "nova-ui/src/**/*.testIds.ts", "nova-ui/src/test-utils", "nova-ui/src/vitest-axe.d.ts", "nova-ui/src/playground"]
}
